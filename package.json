{
  "name": "pi-para",
  "version": "0.6.1",
  "description": "PARA Knowledge Base Extension for pi — persistent, LLM-curated personal wiki",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wiki": {
      "types": "./dist/wiki.d.ts",
      "import": "./dist/wiki.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./frontmatter": {
      "types": "./dist/frontmatter.d.ts",
      "import": "./dist/frontmatter.js"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "import": "./dist/raw.js"
    },
    "./scope": {
      "types": "./dist/scope.d.ts",
      "import": "./dist/scope.js"
    },
    "./lint": {
      "types": "./dist/lint.d.ts",
      "import": "./dist/lint.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    },
    "./ingest": {
      "types": "./dist/ingest.d.ts",
      "import": "./dist/ingest.js"
    },
    "./summarize": {
      "types": "./dist/summarize.d.ts",
      "import": "./dist/summarize.js"
    },
    "./link-utils": {
      "types": "./dist/link-utils.d.ts",
      "import": "./dist/link-utils.js"
    },
    "./tag-registry": {
      "types": "./dist/tag-registry.d.ts",
      "import": "./dist/tag-registry.js"
    },
    "./link-discovery": {
      "types": "./dist/link-discovery.d.ts",
      "import": "./dist/link-discovery.js"
    },
    "./redact": {
      "types": "./dist/redact.d.ts",
      "import": "./dist/redact.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./credentials": {
      "types": "./dist/credentials.d.ts",
      "import": "./dist/credentials.js"
    },
    "./paths": {
      "types": "./dist/paths.d.ts",
      "import": "./dist/paths.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler/index.d.ts",
      "import": "./dist/scheduler/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    },
    "./doctor": {
      "types": "./dist/doctor.d.ts",
      "import": "./dist/doctor.js"
    },
    "./repair": {
      "types": "./dist/repair.d.ts",
      "import": "./dist/repair.js"
    },
    "./scheduler/session-capture": {
      "types": "./dist/scheduler/session-capture.d.ts",
      "import": "./dist/scheduler/session-capture.js"
    },
    "./scheduler/controls": {
      "types": "./dist/scheduler/controls.d.ts",
      "import": "./dist/scheduler/controls.js"
    },
    "./model-resolver": {
      "types": "./dist/model-resolver.d.ts",
      "import": "./dist/model-resolver.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "import": "./dist/settings.js"
    },
    "./qmd-providers": {
      "types": "./dist/qmd-providers.d.ts",
      "import": "./dist/qmd-providers.js"
    },
    "./status": {
      "types": "./dist/status.d.ts",
      "import": "./dist/status.js"
    },
    "./wiki-tool-guidance": {
      "types": "./dist/wiki-tool-guidance.d.ts",
      "import": "./dist/wiki-tool-guidance.js"
    }
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "CHANGELOG.md",
    "README.md",
    "SETUP.md",
    "ARCHITECTURE.md",
    "STRUCTURE.md",
    "CONFIGURATION.md",
    "skills"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json && node scripts/build-assets.mjs",
    "prepack": "npm run build",
    "check": "tsc --noEmit",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "smoke:install": "npm run build && node scripts/smoke-install.mjs",
    "fix-links": "tsx src/scripts/bulk-link-fix.ts",
    "fix-links:dry": "tsx src/scripts/bulk-link-fix.ts --dry-run"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "qmd-engine": "^2.5.0",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "typebox": "^1.1.24"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typebox": "^1.1.34",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "para",
    "knowledge-base",
    "wiki"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/picassio/pi-para.git"
  },
  "homepage": "https://github.com/picassio/pi-para#readme",
  "bugs": {
    "url": "https://github.com/picassio/pi-para/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bin": {
    "pi-para": "./dist/cli.js",
    "pi-para-daemon": "./dist/cli.js"
  }
}
